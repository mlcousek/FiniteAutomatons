@page
@model FiniteAutomatons.Areas.Identity.Pages.Account.Manage.NotificationsModel
@{
    ViewData["Title"] = "Notification Preferences";
    ViewData["ActivePage"] = ManageNavPages.Notifications;
}

<h3 class="text-center">@ViewData["Title"]</h3>
<partial name="_StatusMessage" model="Model.StatusMessage" />

<div class="d-flex justify-content-center">
    <div class="w-100" style="max-width:640px;">
        <form id="notifications-form" method="post" class="d-grid gap-3">
            <div asp-validation-summary="All" class="text-danger" role="alert"></div>

            <div class="form-group">
                <div class="form-check form-switch d-flex align-items-center">
                    <input type="checkbox" class="form-check-input me-3" id="enableInvitationNotifications" 
                           name="enableInvitationNotifications" value="true" 
                           @(Model.EnableInvitationNotifications ? "checked" : "") />
                    <div>
                        <label class="form-check-label" for="enableInvitationNotifications">
                            <strong>Group Invitation Notifications</strong>
                        </label>
                        <div>
                            <small class="text-muted">
                                When enabled, you'll see a notification alert when you log in if you have pending group invitations.
                            </small>
                        </div>
                    </div>
                </div>
            </div>

            <div>
                <button type="submit" class="btn btn-primary">Save Preferences</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
