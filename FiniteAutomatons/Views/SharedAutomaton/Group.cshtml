@using FiniteAutomatons.Core.Models.Database
@model List<SharedAutomaton>
@{
    ViewData["Title"] = "Group Automatons";
    var automatons = Model ?? new List<SharedAutomaton>();
    var group = ViewBag.Group as SharedAutomatonGroup;
    var creatorEmails = ViewData["CreatorEmails"] as Dictionary<string, string> ?? new Dictionary<string, string>();
    var userRole = ViewData["UserRole"] as SharedGroupRole?;
    var currentUserId = ViewData["CurrentUserId"] as string ?? User.Identity?.Name;

    static string TruncateText(string? value, int maxLength)
    {
        if (string.IsNullOrWhiteSpace(value))
            return string.Empty;

        return value.Length <= maxLength
            ? value
            : value[..maxLength] + "...";
    }

    static string ToUtcIso(DateTime dateTime)
    {
        var utc = dateTime.Kind == DateTimeKind.Utc
            ? dateTime
            : DateTime.SpecifyKind(dateTime, DateTimeKind.Utc);
        return utc.ToString("o");
    }
}

<div class="container mt-3">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>
            <i class="fas fa-folder-open"></i>
            Group:
            <span class="d-inline-block align-middle text-truncate" style="max-width: 900px;" title="@group?.Name">@TruncateText(group?.Name, 70)</span>
        </h2>
        <div>
            <a asp-action="Index" asp-controller="SharedAutomaton" class="btn btn-sm btn-outline-secondary">
                <i class="fas fa-arrow-left"></i> Back to Groups
            </a>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(group?.Description))
    {
        <p class="text-muted text-truncate" style="max-width: 1200px;" title="@group.Description">@TruncateText(group.Description, 150)</p>
    }

    <div class="mb-3 d-flex justify-content-end align-items-center gap-2 flex-wrap">
        @if (userRole.HasValue && userRole.Value >= SharedGroupRole.Admin && group != null)
        {
            <a asp-action="ManageMembers" asp-route-groupId="@group.Id" class="btn btn-sm btn-primary">
                <i class="fas fa-users-cog"></i> Manage Members
            </a>
        }
        @if (group != null)
        {
            <a asp-controller="ImportExport" asp-action="ExportGroup" asp-route-groupId="@group.Id" class="btn btn-sm btn-outline-secondary ms-2">
                <i class="fas fa-file-export"></i> Export Group
            </a>

            @if (userRole.HasValue && userRole.Value >= SharedGroupRole.Contributor)
            {
                <form asp-controller="ImportExport" asp-action="ImportGroup" method="post" enctype="multipart/form-data" class="d-inline ms-2" id="importGroupOrAutomatonForm">
                    @Html.AntiForgeryToken()
                    <input type="file" id="importGroupOrAutomatonInput" name="upload" accept=".json,.txt" required style="display:none;" />
                    <input type="hidden" name="groupId" value="@group.Id" />
                    <button type="button" class="btn btn-sm btn-outline-success" id="importGroupOrAutomatonBtn">Import</button>
                </form>
            }
        }
    </div>

    @if (automatons == null || automatons.Count == 0)
    {
        <div class="alert alert-info">No automatons in this group yet.</div>
    }
    else
    {
        <div class="list-group">
            @foreach (var item in automatons)
            {
                <div class="list-group-item">
                    <div class="d-flex justify-content-between align-items-start gap-3">
                        @if (!string.IsNullOrWhiteSpace(item.ThumbnailBase64))
                        {
                            <div class="flex-shrink-0" style="width:120px;">
                                <img src="data:image/png;base64,@item.ThumbnailBase64"
                                     alt="Preview of @item.Name"
                                     class="img-fluid rounded thumb-preview"
                                     style="max-height:80px;object-fit:contain;background:#fff;border:1.5px solid #000;cursor:pointer;"
                                     title="Click to enlarge" />
                            </div>
                        }
                        <div class="flex-grow-1" style="min-width: 0;">
                            <h5 class="mb-1 text-truncate" title="@item.Name">@TruncateText(item.Name, 70)</h5>
                            @if (!string.IsNullOrWhiteSpace(item.Description))
                            {
                                <p class="mb-1 text-muted text-truncate" title="@item.Description">@TruncateText(item.Description, 110)</p>
                            }
                            @{ var creatorText = creatorEmails.ContainsKey(item.CreatedByUserId) ? creatorEmails[item.CreatedByUserId] : item.CreatedByUserId; }
                            <small class="text-muted">
                                <i class="fas fa-user"></i> Created by:
                                <strong class="d-inline-block align-middle text-truncate" style="max-width: 280px;" title="@creatorText">@TruncateText(creatorText, 40)</strong>
                                • <i class="fas fa-clock"></i> <span class="js-local-datetime" data-utc="@ToUtcIso(item.CreatedAt)">@item.CreatedAt</span>
                            </small>
                        </div>
                        <div class="text-end ms-3">
                            <a asp-controller="SharedAutomaton" asp-action="Load" asp-route-id="@item.Id" asp-route-mode="structure" class="btn btn-sm btn-primary mb-1">
                                <i class="fas fa-upload"></i> Load
                            </a>
                            @if (item.SaveMode >= AutomatonSaveMode.WithInput)
                            {
                                <a asp-controller="SharedAutomaton" asp-action="Load" asp-route-id="@item.Id" asp-route-mode="input" class="btn btn-sm btn-info mb-1">
                                    <i class="fas fa-keyboard"></i> Load with Input
                                </a>
                            }
                            @if (item.SaveMode == AutomatonSaveMode.WithState)
                            {
                                <a asp-controller="SharedAutomaton" asp-action="Load" asp-route-id="@item.Id" asp-route-mode="state" class="btn btn-sm btn-outline-primary mb-1">
                                    <i class="fas fa-play-circle"></i> Load as State
                                </a>
                            }

                            <a asp-controller="ImportExport" asp-action="ExportShared" asp-route-id="@item.Id" asp-route-format="json" asp-route-mode="structure" class="btn btn-sm btn-outline-secondary mb-1 ms-1">
                                <i class="fas fa-file-export"></i> Export
                            </a>

                            @{ var canDelete = (userRole.HasValue && userRole.Value >= SharedGroupRole.Editor) || item.CreatedByUserId == currentUserId; }
                            @if (canDelete)
                            {
                                <form asp-action="Delete" asp-controller="SharedAutomaton" method="post" class="d-inline ms-1">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@item.Id" />
                                    <button type="submit" class="btn btn-sm btn-danger mb-1" onclick="return confirm('Delete this shared automaton?');">
                                        <i class="fas fa-trash"></i> Delete
                                    </button>
                                </form>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

<div id="thumbLightbox" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.7);z-index:9999;align-items:center;justify-content:center;cursor:zoom-out;">
    <img id="thumbLightboxImg" src="" alt="" style="max-width:90vw;max-height:90vh;border:2px solid #000;border-radius:4px;background:#fff;box-shadow:0 8px 40px rgba(0,0,0,0.5);" />
</div>

<script>
    (function () {
        var nodes = document.querySelectorAll('.js-local-datetime[data-utc]');
        nodes.forEach(function (el) {
            var raw = el.getAttribute('data-utc');
            if (!raw) return;
            var dt = new Date(raw);
            if (Number.isNaN(dt.getTime())) return;
            el.textContent = dt.toLocaleString();
            el.title = dt.toLocaleString();
        });
    })();

    (function() {
        var importBtn = document.getElementById('importGroupOrAutomatonBtn');
        var importInput = document.getElementById('importGroupOrAutomatonInput');
        var importForm = document.getElementById('importGroupOrAutomatonForm');
        if (!importBtn || !importInput || !importForm) return;

        importBtn.addEventListener('click', function() {
            importInput.click();
        });

        importInput.addEventListener('change', function() {
            if (importInput.files && importInput.files.length > 0) {
                importForm.submit();
            }
        });
    })();

    (function(){
        var lightbox = document.getElementById('thumbLightbox');
        var lightboxImg = document.getElementById('thumbLightboxImg');
        if (!lightbox || !lightboxImg) return;

        document.addEventListener('click', function(e) {
            var thumb = e.target.closest('.thumb-preview');
            if (thumb) {
                lightboxImg.src = thumb.src;
                lightboxImg.alt = thumb.alt;
                lightbox.style.display = 'flex';
                return;
            }
            if (lightbox.style.display === 'flex') {
                lightbox.style.display = 'none';
                lightboxImg.src = '';
            }
        });

        document.addEventListener('keydown', function(e) {
            if (e.key === 'Escape' && lightbox.style.display === 'flex') {
                lightbox.style.display = 'none';
                lightboxImg.src = '';
            }
        });
    })();
</script>
