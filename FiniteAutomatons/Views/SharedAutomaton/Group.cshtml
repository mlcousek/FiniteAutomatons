@using FiniteAutomatons.Core.Models.Database
@model List<SharedAutomaton>
@{
    ViewData["Title"] = "Group Automatons";
    var automatons = Model ?? new List<SharedAutomaton>();
    var group = ViewBag.Group as SharedAutomatonGroup;
    var creatorEmails = ViewData["CreatorEmails"] as Dictionary<string, string> ?? new Dictionary<string, string>();
    var userRole = ViewData["UserRole"] as SharedGroupRole?;
    var currentUserId = ViewData["CurrentUserId"] as string ?? User.Identity?.Name;
}

<div class="container mt-3">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2><i class="fas fa-folder-open"></i> Group: @group?.Name</h2>
        <div>
            <a asp-action="Index" asp-controller="SharedAutomaton" class="btn btn-sm btn-outline-secondary">
                <i class="fas fa-arrow-left"></i> Back to Groups
            </a>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(group?.Description))
    {
        <p class="text-muted">@group.Description</p>
    }

    <div class="mb-3">
        @if (userRole.HasValue && userRole.Value >= SharedGroupRole.Admin && group != null)
        {
            <a asp-action="ManageMembers" asp-route-groupId="@group.Id" class="btn btn-sm btn-primary">
                <i class="fas fa-users-cog"></i> Manage Members
            </a>
        }
        @* Export / Import group *@
        @if (group != null)
        {
            <a asp-controller="ImportExport" asp-action="ExportGroup" asp-route-groupId="@group.Id" class="btn btn-sm btn-outline-secondary ms-2">
                <i class="fas fa-file-export"></i> Export Group
            </a>

            @if (userRole.HasValue && userRole.Value >= SharedGroupRole.Contributor)
            {
                <form asp-controller="ImportExport" asp-action="ImportGroup" method="post" enctype="multipart/form-data" class="d-inline ms-2">
                    @Html.AntiForgeryToken()
                    <input type="file" name="upload" accept="application/json" required style="display:inline-block;vertical-align:middle;" />
                    <input type="hidden" name="groupId" value="@group.Id" />
                    <button type="submit" class="btn btn-sm btn-outline-success">Import Group</button>
                </form>
            }
        }
    </div>

    @if (automatons == null || automatons.Count == 0)
    {
        <div class="alert alert-info">No automatons in this group yet.</div>
    }
    else
    {
        <div class="list-group">
            @foreach (var item in automatons)
            {
                <div class="list-group-item">
                    <div class="d-flex justify-content-between align-items-start">
                        <div class="flex-grow-1">
                            <h5 class="mb-1">@item.Name</h5>
                            @if (!string.IsNullOrWhiteSpace(item.Description))
                            {
                                <p class="mb-1 text-muted">@item.Description</p>
                            }
                            <small class="text-muted">
                                <i class="fas fa-user"></i> Created by: <strong>@(creatorEmails.ContainsKey(item.CreatedByUserId) ? creatorEmails[item.CreatedByUserId] : item.CreatedByUserId)</strong>
                                • <i class="fas fa-clock"></i> @item.CreatedAt.ToLocalTime().ToString("g")
                            </small>
                        </div>
                        <div class="text-end ms-3">
                            <a asp-controller="SharedAutomaton" asp-action="Load" asp-route-id="@item.Id" asp-route-mode="structure" class="btn btn-sm btn-primary mb-1">
                                <i class="fas fa-upload"></i> Load
                            </a>
                            @if (item.SaveMode >= AutomatonSaveMode.WithInput)
                            {
                                <a asp-controller="SharedAutomaton" asp-action="Load" asp-route-id="@item.Id" asp-route-mode="input" class="btn btn-sm btn-info mb-1">
                                    <i class="fas fa-keyboard"></i> Load with Input
                                </a>
                            }
                            @if (item.SaveMode == AutomatonSaveMode.WithState)
                            {
                                <a asp-controller="SharedAutomaton" asp-action="Load" asp-route-id="@item.Id" asp-route-mode="state" class="btn btn-sm btn-outline-primary mb-1">
                                    <i class="fas fa-play-circle"></i> Load as State
                                </a>
                            }

                            @* Export options - available to all group members *@
                            <a asp-controller="ImportExport" asp-action="ExportShared" asp-route-id="@item.Id" asp-route-format="json" asp-route-mode="structure" class="btn btn-sm btn-outline-secondary mb-1 ms-1">
                                <i class="fas fa-file-export"></i> Export
                            </a>

                            @* Delete - allowed if owner or role >= Editor *@
                            @{ var canDelete = (userRole.HasValue && userRole.Value >= SharedGroupRole.Editor) || item.CreatedByUserId == currentUserId; }
                            @if (canDelete)
                            {
                                <form asp-action="Delete" asp-controller="SharedAutomaton" method="post" class="d-inline ms-1">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@item.Id" />
                                    <button type="submit" class="btn btn-sm btn-danger mb-1" onclick="return confirm('Delete this shared automaton?');">
                                        <i class="fas fa-trash"></i> Delete
                                    </button>
                                </form>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
