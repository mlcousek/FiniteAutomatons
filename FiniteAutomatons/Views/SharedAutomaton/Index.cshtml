@using FiniteAutomatons.Core.Models.Database
@model List<SharedAutomatonGroup>
@{
    ViewData["Title"] = "Shared Groups";
    var groups = Model ?? new List<SharedAutomatonGroup>();
    var pendingInvitations = ViewData["PendingInvitations"] as List<SharedAutomatonGroupInvitation>;
    var groupRoles = ViewData["GroupRoles"] as Dictionary<int, SharedGroupRole?> ?? new Dictionary<int, SharedGroupRole?>();
    var ownerEmails = ViewData["OwnerEmails"] as Dictionary<string, string> ?? new Dictionary<string, string>();
}

<div class="container mt-3">
    <div class="d-flex justify-content-between align-items-center">
        <h2><i class="fas fa-users"></i> Shared Automatons</h2>
    </div>

    @if (TempData["CreateGroupResult"] is string createMsg && !string.IsNullOrWhiteSpace(createMsg))
    {
        var success = TempData["CreateGroupSuccess"] as string == "1";
        <div class="row mb-3">
            <div class="col-12">
                <div class="alert @(success ? "alert-success" : "alert-danger") alert-dismissible fade show">
                    @createMsg
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            </div>
        </div>
    }

    @if (TempData["Error"] is string errorMsg)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            @errorMsg
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (pendingInvitations != null && pendingInvitations.Count > 0)
    {
        <div class="alert alert-info alert-dismissible fade show" role="alert">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <i class="fas fa-envelope-open-text"></i>
                    <strong>You have @pendingInvitations.Count pending group @(pendingInvitations.Count == 1 ? "invitation" : "invitations")!</strong>
                    <br />
                    <small>Review and accept invitations to start collaborating.</small>
                </div>
                <div class="ms-2">
                    <a asp-controller="SharedAutomaton" asp-action="Invitations" class="btn btn-sm btn-primary me-2">
                        <i class="fas fa-inbox"></i> View All
                    </a>
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            </div>
        </div>
    }

    <div class="modal fade" id="createGroupModal" tabindex="-1" aria-labelledby="createGroupModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content">
                <form asp-action="CreateGroup" asp-controller="SharedAutomaton" method="post">
                    @Html.AntiForgeryToken()
                    <div class="modal-header py-3 px-4">
                        <h5 class="modal-title mb-0" id="createGroupModalLabel">Create Shared Group</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body py-4 px-4">
                        <div class="mb-3">
                            <label for="groupName" class="form-label">Name</label>
                            <input id="groupName" name="name" required class="form-control" placeholder="Enter group name" />
                        </div>
                        <div class="mb-3">
                            <label for="groupDescription" class="form-label">Description (optional)</label>
                            <textarea id="groupDescription" name="description" class="form-control" rows="3" placeholder="Describe the purpose of this group"></textarea>
                        </div>
                        <div class="alert alert-info">
                            <i class="fas fa-info-circle"></i> You will be the owner of this group and can invite others to collaborate.
                        </div>
                    </div>
                    <div class="modal-footer py-3 px-4">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-success">Create Group</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="row mb-3">
        <div class="col-md-8">
            <h4 class="mb-0">Your Groups</h4>
        </div>
        <div class="col-md-4 text-end">
            <button type="button" class="btn btn-sm btn-success" data-bs-toggle="modal" data-bs-target="#createGroupModal">
                <i class="fas fa-plus"></i> Create Group
            </button>
        </div>
    </div>

    @if (groups == null || groups.Count == 0)
    {
        <div class="alert alert-info">
            <i class="fas fa-info-circle"></i>
            You are not a member of any groups. Create a new group or ask someone to invite you.
        </div>
    }
    else
    {
        <div class="list-group">
            @foreach (var g in groups)
            {
                var roleNullable = groupRoles.ContainsKey(g.Id) ? groupRoles[g.Id] : null;
                var role = roleNullable ?? SharedGroupRole.Viewer;
                <div class="list-group-item">
                    <div class="d-flex justify-content-between align-items-start">
                        <div class="flex-grow-1">
                            <h5 class="mb-1">
                                <a asp-action="Group" asp-controller="SharedAutomaton" asp-route-id="@g.Id" class="text-decoration-none text-reset">
                                    @g.Name
                                </a>
                            </h5>
                            @if (!string.IsNullOrWhiteSpace(g.Description))
                            {
                                <p class="mb-1 text-muted">@g.Description</p>
                            }
                            <small class="text-muted">
                                <i class="fas fa-user"></i> Owner: <strong>@(ownerEmails.ContainsKey(g.UserId) ? ownerEmails[g.UserId] : g.UserId)</strong>
                                • <i class="fas fa-clock"></i> @g.CreatedAt.ToLocalTime().ToString("g")
                            </small>
                        </div>

                        <div class="text-end ms-3">
                            <a asp-action="Group" asp-route-id="@g.Id" class="btn btn-sm btn-primary mb-1">
                                <i class="fas fa-folder-open"></i> Open Group
                            </a>
                            @if (role >= SharedGroupRole.Admin)
                            {
                                <a asp-action="ManageMembers" asp-route-groupId="@g.Id" class="btn btn-sm btn-secondary mb-1 ms-1">
                                    <i class="fas fa-users-cog"></i> Manage Members
                                </a>
                            }
                            @if (role == SharedGroupRole.Owner)
                            {
                                <form asp-action="DeleteGroup" asp-controller="SharedAutomaton" method="post" class="d-inline ms-1" onsubmit="return confirm('Delete this group? All automatons will become unassigned.');">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@g.Id" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger mb-1">
                                        <i class="fas fa-trash"></i> Delete Group
                                    </button>
                                </form>
                            }
                            else
                            {
                                <form asp-action="LeaveGroup" asp-controller="SharedAutomaton" method="post" class="d-inline ms-1" onsubmit="return confirm('Leave this group?');">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="groupId" value="@g.Id" />
                                    <button type="submit" class="btn btn-sm btn-outline-secondary mb-1">
                                        <i class="fas fa-sign-out-alt"></i> Leave Group
                                    </button>
                                </form>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

<style>
.badge {
    font-size: 0.75rem;
}
</style>
