@using FiniteAutomatons.Core.Models.Database
@model List<SavedAutomaton>
@{
    ViewData["Title"] = "Saved Automatons";
    var groups = ViewData["Groups"] as List<SavedAutomatonGroup> ?? new List<SavedAutomatonGroup>();
    var sharedGroups = ViewData["SharedGroups"] as List<SharedAutomatonGroup> ?? new List<SharedAutomatonGroup>();
    var selectedGroup = ViewData["SelectedGroupId"] as int?;
}

<div class="container mt-3">
    <div class="d-flex justify-content-between align-items-center">
        <h2>Saved Automatons</h2>
    </div>

    @if (TempData["CreateGroupResult"] is string createMsg && !string.IsNullOrWhiteSpace(createMsg))
    {
        var success = TempData["CreateGroupSuccess"] as string == "1";
        <div class="row mb-3">
            <div class="col-12">
                <div class="alert @(success ? "alert-success" : "alert-info")">@createMsg</div>
            </div>
        </div>
    }

<!-- Create Group Modal (placed outside loop) -->
<div class="modal fade" id="createGroupModal" tabindex="-1" aria-labelledby="createGroupModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <form asp-action="CreateGroup" asp-controller="SavedAutomaton" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-header py-3 px-4">
                    <h5 class="modal-title mb-0" id="createGroupModalLabel">Create Group</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body py-4 px-4">
                    <div class="mb-3">
                        <label for="groupName" class="form-label">Name</label>
                        <input id="groupName" name="name" required class="form-control" />
                    </div>
                    <div class="mb-3">
                        <label for="groupDescription" class="form-label">Description (optional)</label>
                        <input id="groupDescription" name="description" class="form-control" />
                    </div>
                </div>
                <div class="modal-footer py-3 px-4">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Create</button>
                </div>
            </form>
        </div>
    </div>
</div>

    <div class="row mb-3">
        <div class="col-md-8">
            <form method="get" asp-action="Index" asp-controller="SavedAutomaton" class="d-flex gap-2 align-items-center">
                <label class="mb-0">Filter by group:</label>
                <select name="groupId" class="form-select" style="width:auto;" onchange="this.form.submit()">
                    <option value="">All</option>
                    @foreach (var g in groups)
                    {
                        if (selectedGroup.HasValue && selectedGroup.Value == g.Id)
                        {
                            <option value="@g.Id" selected>@g.Name</option>
                        }
                        else
                        {
                            <option value="@g.Id">@g.Name</option>
                        }
                    }
                </select>
            </form>
        </div>
        <div class="col-md-4 text-end">
            <button type="button" class="btn btn-sm btn-success" data-bs-toggle="modal" data-bs-target="#createGroupModal">Create Group</button>
            @if (selectedGroup.HasValue)
            {
                <a asp-action="ExportGroup" asp-controller="SavedAutomaton" asp-route-groupId="@selectedGroup.Value" class="btn btn-sm btn-primary ms-2">
                    <i class="fas fa-file-export"></i> Export Group
                </a>
                <button type="button" class="btn btn-sm btn-primary ms-1" data-bs-toggle="modal" data-bs-target="#importGroupModal">
                    <i class="fas fa-file-import"></i> Import Group
                </button>
                <form asp-action="DeleteGroup" asp-controller="SavedAutomaton" method="post" class="d-inline ms-1" onsubmit="return confirm('Delete this group? This will ungroup all automatons.');">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@selectedGroup.Value" />
                    <button type="submit" class="btn btn-sm btn-outline-danger">Delete Group</button>
                </form>
            }
        </div>
    </div>

    @* no error messages shown after create group *@

    @if (Model == null || Model.Count == 0)
    {
        <div class="alert alert-info">You have no saved automatons yet.</div>
    }
    else
    {
        <div class="list-group">
            @foreach (var item in Model)

            {
                <div class="list-group-item">
                    <div class="d-flex justify-content-between align-items-start gap-3">
                        @* Thumbnail (if available) *@
                        @if (!string.IsNullOrWhiteSpace(item.ThumbnailBase64))
                        {
                            <div class="flex-shrink-0" style="width:120px;">
                                <img src="data:image/png;base64,@item.ThumbnailBase64"
                                     alt="Preview of @item.Name"
                                     class="img-fluid rounded thumb-preview"
                                     style="max-height:80px;object-fit:contain;background:#fff;border:1.5px solid #000;cursor:pointer;"
                                     title="Click to enlarge" />
                            </div>
                        }
                        <div class="flex-grow-1">
                            <h5 class="mb-1">@item.Name</h5>
                            @if (!string.IsNullOrWhiteSpace(item.Description))
                            {
                                <p class="mb-1 text-muted">@item.Description</p>
                            }
                            <small class="text-muted">
                                Created: @item.CreatedAt.ToLocalTime().ToString("g")
                                @if (item.Assignments != null && item.Assignments.Count > 0)
                                {
                                    <text>• Groups: @string.Join(", ", item.Assignments.Select(a => a.Group?.Name ?? a.GroupId.ToString()))</text>
                                }
                            </small>
                        </div>

                        
                        
                        <div class="text-end">
                            @{
                                // Use SaveMode property for reliable button visibility
                                var hasInput = item.SaveMode >= AutomatonSaveMode.WithInput;
                                var hasState = item.SaveMode == AutomatonSaveMode.WithState;
                            }

                            @* Always show Load (structure only) *@
                            <a asp-controller="SavedAutomaton" asp-action="Load" asp-route-id="@item.Id" asp-route-mode="structure" class="btn btn-sm btn-primary mb-1">Load</a>
                            
                            @* Show "Load with Input" if input was saved *@
                            @if (hasInput)
                            {
                                <a asp-controller="SavedAutomaton" asp-action="Load" asp-route-id="@item.Id" asp-route-mode="input" class="btn btn-sm btn-info mb-1">Load with Input</a>
                            }
                            
                            @* Show "Load as State" if execution state was saved *@
                            @if (hasState)
                            {
                                <a asp-controller="SavedAutomaton" asp-action="Load" asp-route-id="@item.Id" asp-route-mode="state" class="btn btn-sm btn-outline-primary mb-1">Load as State</a>
                            }
                            
                            <button type="button" class="btn btn-sm btn-outline-info mb-1" data-bs-toggle="modal" data-bs-target="#exportModal" data-automaton-id="@item.Id" data-automaton-name="@item.Name">
                                <i class="fas fa-download"></i> Export
                            </button>
                            <button type="button" class="btn btn-sm btn-outline-success mb-1" data-bs-toggle="modal" data-bs-target="#shareModal" data-automaton-id="@item.Id" data-automaton-name="@item.Name">
                                <i class="fas fa-share-alt"></i> Share
                            </button>
                            <button type="button" class="btn btn-sm btn-outline-secondary mb-1" data-bs-toggle="modal" data-bs-target="#assignGroupModal" data-automaton-id="@item.Id" data-automaton-group="@((item.Assignments != null && item.Assignments.Any()) ? item.Assignments.First().GroupId.ToString() : String.Empty)">Add to Group</button>
                            @if (selectedGroup.HasValue && item.Assignments != null && item.Assignments.Any(a => a.GroupId == selectedGroup.Value))
                            {
                                <form asp-action="RemoveFromGroup" asp-controller="SavedAutomaton" method="post" class="d-inline ms-1">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="automatonId" value="@item.Id" />
                                    <input type="hidden" name="groupId" value="@selectedGroup.Value" />
                                    <button type="submit" class="btn btn-sm btn-outline-warning mb-1" onclick="return confirm('Remove this automaton from the group?');">Remove from Group</button>
                                </form>
                            }
                            <form asp-action="Delete" asp-controller="SavedAutomaton" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@item.Id" />
                                <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Delete this saved automaton?');">Delete</button>
                            </form>
                        </div>
                    </div>
                </div>
            }
        </div>


    }

    <!-- Assign to Group Modal (single instance) -->
    <div class="modal fade" id="assignGroupModal" tabindex="-1" aria-labelledby="assignGroupModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <form asp-action="AssignToGroup" asp-controller="SavedAutomaton" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" id="assignAutomatonId" name="automatonId" value="" />
                    <div class="modal-header py-3 px-4">
                        <h5 class="modal-title mb-0" id="assignGroupModalLabel">Add to Group</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body py-4 px-4">
                        <div class="mb-3">
                            <label for="selectGroup" class="form-label">Choose group</label>
                            <select id="selectGroup" name="groupId" class="form-select mt-2">
                                <option value="">(No group)</option>
                                @foreach (var g in groups)
                                {
                                    <option value="@g.Id">@g.Name</option>
                                }
                            </select>
                        </div>
                    </div>
                    <div class="modal-footer py-3 px-4">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-primary">Save</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Export Modal (single instance) -->
    <div class="modal fade" id="exportModal" tabindex="-1" aria-labelledby="exportModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content">
                <div class="modal-header py-3 px-4">
                    <h5 class="modal-title mb-0" id="exportModalLabel">Export Automaton</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body py-4 px-4">
                    <p class="mb-3">Export <strong id="exportAutomatonName"></strong>:</p>
                    <input type="hidden" id="exportAutomatonId" value="" />
                    
                    <div class="row g-3">
                        <div class="col-md-6">
                            <h6 class="mb-2">Structure Only</h6>
                            <p class="text-muted small">Export automaton structure (states and transitions)</p>
                            <div class="d-grid gap-2">
                                <button type="button" class="btn btn-outline-primary" onclick="exportSavedAutomaton('json', 'structure')">
                                    <i class="fas fa-code"></i> JSON Format
                                </button>
                                <button type="button" class="btn btn-outline-primary" onclick="exportSavedAutomaton('txt', 'structure')">
                                    <i class="fas fa-file-alt"></i> Text Format
                                </button>
                            </div>
                        </div>
                        
                        <div class="col-md-6">
                            <h6 class="mb-2">With Input</h6>
                            <p class="text-muted small">Export structure + input string (no execution state)</p>
                            <div class="d-grid gap-2">
                                <button type="button" class="btn btn-outline-info" onclick="exportSavedAutomaton('json', 'input')">
                                    <i class="fas fa-keyboard"></i> Export with Input
                                </button>
                            </div>
                        </div>
                        
                        <div class="col-12 mt-4">
                            <h6 class="mb-2">Full Execution State</h6>
                            <p class="text-muted small">Export everything (structure, input, position, current states, history)</p>
                            <div class="d-grid">
                                <button type="button" class="btn btn-outline-success" onclick="exportSavedAutomaton('json', 'state')">
                                    <i class="fas fa-save"></i> Export Full State
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer py-3 px-4">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Import Group Modal -->
    <div class="modal fade" id="importGroupModal" tabindex="-1" aria-labelledby="importGroupModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <form asp-action="ImportGroup" asp-controller="SavedAutomaton" method="post" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()
                    @if (selectedGroup.HasValue)
                    {
                        <input type="hidden" name="groupId" value="@selectedGroup.Value" />
                    }
                    <div class="modal-header py-3 px-4">
                        <h5 class="modal-title mb-0" id="importGroupModalLabel">Import Group</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body py-4 px-4">
                        <p class="mb-3">Upload a JSON file containing the group export:</p>
                        <div class="mb-3">
                            <label for="groupFile" class="form-label">Choose file</label>
                            <input type="file" class="form-control" id="groupFile" name="file" accept=".json" required />
                        </div>
                        <div class="alert alert-info">
                            <i class="fas fa-info-circle"></i> The file should contain all automatons from the exported group.
                        </div>
                    </div>
                    <div class="modal-footer py-3 px-4">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-primary">Import</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Share Modal -->
    <div class="modal fade" id="shareModal" tabindex="-1" aria-labelledby="shareModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <form asp-action="ShareToGroup" asp-controller="SavedAutomaton" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" id="shareAutomatonId" name="id" value="" />
                    <div class="modal-header py-3 px-4">
                        <h5 class="modal-title mb-0" id="shareModalLabel">Share Automaton to Group</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body py-4 px-4">
                        <p class="mb-3">Share <strong id="shareAutomatonName"></strong> to a collaborative group:</p>
                        
                        @if (sharedGroups.Count > 0)
                        {
                            <div class="mb-3">
                                <label for="shareGroupId" class="form-label">Select Group</label>
                                <select id="shareGroupId" name="groupId" class="form-select" required>
                                    <option value="" selected disabled>Choose a group...</option>
                                    @foreach (var sg in sharedGroups)
                                    {
                                        <option value="@sg.Id">@sg.Name</option>
                                    }
                                </select>
                            </div>
                            <div class="alert alert-info small">
                                <i class="fas fa-info-circle"></i> This will create a copy of the automaton in the selected group.
                            </div>
                        }
                        else
                        {
                            <div class="alert alert-warning">
                                <i class="fas fa-exclamation-triangle"></i> You are not a member of any shared groups yet.
                            </div>
                            <div class="text-center">
                                <a asp-controller="SharedAutomaton" asp-action="Index" class="btn btn-primary btn-sm">
                                    <i class="fas fa-users"></i> Go to Shared Groups
                                </a>
                            </div>
                        }
                    </div>
                    <div class="modal-footer py-3 px-4">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        @if (sharedGroups.Count > 0)
                        {
                            <button type="submit" class="btn btn-success">Share Now</button>
                        }
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>


<!-- Thumbnail Lightbox -->
<div id="thumbLightbox" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.7);z-index:9999;align-items:center;justify-content:center;cursor:zoom-out;">
    <img id="thumbLightboxImg" src="" alt="" style="max-width:90vw;max-height:90vh;border:2px solid #000;border-radius:4px;background:#fff;box-shadow:0 8px 40px rgba(0,0,0,0.5);" />
</div>

<script>
    // Thumbnail lightbox
    (function(){
        var lightbox = document.getElementById('thumbLightbox');
        var lightboxImg = document.getElementById('thumbLightboxImg');
        if (!lightbox || !lightboxImg) return;

        document.addEventListener('click', function(e) {
            var thumb = e.target.closest('.thumb-preview');
            if (thumb) {
                lightboxImg.src = thumb.src;
                lightboxImg.alt = thumb.alt;
                lightbox.style.display = 'flex';
                return;
            }
            if (lightbox.style.display === 'flex') {
                lightbox.style.display = 'none';
                lightboxImg.src = '';
            }
        });

        // Also close on Escape key
        document.addEventListener('keydown', function(e) {
            if (e.key === 'Escape' && lightbox.style.display === 'flex') {
                lightbox.style.display = 'none';
                lightboxImg.src = '';
            }
        });
    })();

    (function(){
        var assignModal = document.getElementById('assignGroupModal');
        if (!assignModal) return;
        assignModal.addEventListener('show.bs.modal', function (event) {
            var button = event.relatedTarget;
            var automatonId = button.getAttribute('data-automaton-id');
            var automatonGroup = button.getAttribute('data-automaton-group');
            var input = document.getElementById('assignAutomatonId');
            var select = document.getElementById('selectGroup');
            if (input) input.value = automatonId || '';
            if (select) {
                if (automatonGroup) {
                    for (var i=0;i<select.options.length;i++){
                        if (select.options[i].value === automatonGroup) { select.selectedIndex = i; break; }
                    }
                } else {
                    select.selectedIndex = 0;
                }
            }
        });
    })();

    // Handle export modal
    (function(){
        var exportModal = document.getElementById('exportModal');
        if (!exportModal) return;
        exportModal.addEventListener('show.bs.modal', function (event) {
            var button = event.relatedTarget;
            var automatonId = button.getAttribute('data-automaton-id');
            var automatonName = button.getAttribute('data-automaton-name');
            var input = document.getElementById('exportAutomatonId');
            var nameDisplay = document.getElementById('exportAutomatonName');
            if (input) input.value = automatonId || '';
            if (nameDisplay) nameDisplay.textContent = automatonName || '';
        });
    })();

    // Export function
    function exportSavedAutomaton(format, mode) {
        var automatonId = document.getElementById('exportAutomatonId').value;
        if (!automatonId) {
            alert('No automaton selected');
            return;
        }
        
        // Close the modal
        var modal = bootstrap.Modal.getInstance(document.getElementById('exportModal'));
        if (modal) modal.hide();
        
        // Redirect to export endpoint with the saved automaton ID, format, and mode
        var url = '@Url.Action("ExportSaved", "ImportExport")?id=' + automatonId + '&format=' + format + '&mode=' + mode;
        window.location.href = url;
    }

    // Handle share modal
    (function(){
        var shareModal = document.getElementById('shareModal');
        if (!shareModal) return;
        shareModal.addEventListener('show.bs.modal', function (event) {
            var button = event.relatedTarget;
            var automatonId = button.getAttribute('data-automaton-id');
            var automatonName = button.getAttribute('data-automaton-name');
            var input = document.getElementById('shareAutomatonId');
            var nameDisplay = document.getElementById('shareAutomatonName');
            if (input) input.value = automatonId || '';
            if (nameDisplay) nameDisplay.textContent = automatonName || '';
        });
    })();
</script>
