@model AutomatonViewModel
<!-- Hidden opener kept for compatibility with the canvas save button -->
<button id="openSaveModalBtn" type="button" style="display:none;" aria-hidden="true"></button>
<div id="saveAutomatonModal" class="modal modern-modal" style="display:none;">
    <div class="modal-content modern-modal-content" style="padding:1rem;">
        <div class="modal-header">
            <div class="modal-header-content">
                <i class="fas fa-save modal-icon"></i>
                <h3 class="modal-title">Save Automaton</h3>
            </div>
            <button class="modal-close modern-close" id="saveModalClose" type="button">
                <i class="fas fa-times"></i>
            </button>
        </div>
        <div class="modal-body">
            <!-- Save intent selection – only shown when an automaton was loaded -->
            <div id="saveIntentGroup" class="form-group" style="display:none;">
                <label class="form-label">Save as</label>
                <div>
                    <label style="display:flex;align-items:center;gap:0.4rem;margin-bottom:0.3rem;">
                        <input type="radio" name="saveIntent" value="update" id="saveIntentUpdate" checked />
                        Update existing automaton
                    </label>
                    <label style="display:flex;align-items:center;gap:0.4rem;">
                        <input type="radio" name="saveIntent" value="new" id="saveIntentNew" />
                        Save as new automaton
                    </label>
                </div>
            </div>
            <form id="saveAutomatonForm" asp-controller="SavedAutomaton" asp-action="Save" method="post" class="modern-form">
                <!-- Hidden field for the loaded automaton id (used when updating) -->
                <input type="hidden" name="id" id="saveLoadedId" value="" />
                <div class="form-group">
                    <label class="form-label">Name</label>
                    <input type="text" name="name" id="saveName" class="modern-input" required maxlength="200" />
                </div>
                <div class="form-group">
                    <label class="form-label">Description (optional)</label>
                    <input type="text" name="description" id="saveDescription" class="modern-input" maxlength="500" />
                </div>

                @{
                    // Whether execution has ever been started (server-rendered initial flag for JS)
                    var executionStarted = Model?.HasExecuted ?? false;
                }
                <div class="form-group" id="saveOptionsGroup">
                    <label class="form-label">Save Options</label>

                    <!-- Always render all three options; JS controls visibility -->
                    <div id="saveOptionStructureRow">
                        <label><input type="radio" name="saveMode" value="structure" id="saveModeStructure" checked /> Automaton only</label>
                    </div>
                    <div id="saveOptionInputRow" style="display:none;">
                        <label><input type="radio" name="saveMode" value="input" id="saveModeInput" /> Include input</label>
                    </div>
                    <div id="saveOptionStateRow" style="display:none;">
                        <label><input type="radio" name="saveMode" value="state" id="saveModeState" /> Include execution state</label>
                    </div>
                    <!-- Hint shown when only structure is possible (no input, no state) -->
                    <div id="saveStructureOnlyHint" class="form-hint" style="display:none;">Only automaton structure will be saved (no input/execution state present).</div>
                </div>
                <!-- JS uses this data attribute as the initial server-side HasExecuted value -->
                <input type="hidden" id="serverHasExecuted" value="@executionStarted.ToString().ToLowerInvariant()" />

                @{ 
                    // render hidden automaton fields (duplicate of export helper)
                    void RenderAutomatonHiddenFieldsForSave()
                    {
                        if (Model != null)
                        {
                            <input type="hidden" name="Type" value="@Model.Type" />
                            <input type="hidden" name="Input" id="saveInputField" value="@Model.Input" />
                            <input type="hidden" name="HasExecuted" id="saveHasExecuted" value="@Model.HasExecuted.ToString().ToLowerInvariant()" />
                            <input type="hidden" name="Position" id="savePosition" value="@Model.Position" />
                            <input type="hidden" name="CurrentStateId" id="saveCurrentStateId" value="@(Model.CurrentStateId.HasValue ? Model.CurrentStateId.ToString() : "")" />
                            <input type="hidden" name="IsAccepted" id="saveIsAccepted" value="@(Model.IsAccepted.HasValue ? Model.IsAccepted.Value.ToString().ToLowerInvariant() : "")" />
                            <input type="hidden" name="StateHistorySerialized" id="saveStateHistorySerialized" value="@Model.StateHistorySerialized" />
                            <input type="hidden" name="StackSerialized" id="saveStackSerialized" value="@Model.StackSerialized" />
                             <input type="hidden" name="InitialStackSerialized" value="@Model.InitialStackSerialized" />
                             <input type="hidden" name="NPDAConfigurationsSerialized" value="@Model.NPDAConfigurationsSerialized" />
                             <input type="hidden" name="AcceptanceMode" value="@((int)Model.AcceptanceMode)" />
                             <input type="hidden" name="LoadedAutomatonId" value="@(Model.LoadedAutomatonId.HasValue ? Model.LoadedAutomatonId.ToString() : "")" />
                            <input type="hidden" name="IsCustomAutomaton" value="@Model.IsCustomAutomaton.ToString().ToLowerInvariant()" />
                            if (Model.States != null)
                            {
                                for (int i = 0; i < Model.States.Count; i++)
                                {
                                    <input type="hidden" name="States.Index" value="@i" />
                                    <input type="hidden" name="States[@i].Id" value="@Model.States[i].Id" />
                                    <input type="hidden" name="States[@i].IsStart" value="@Model.States[i].IsStart.ToString().ToLowerInvariant()" />
                                    <input type="hidden" name="States[@i].IsAccepting" value="@Model.States[i].IsAccepting.ToString().ToLowerInvariant()" />
                                }
                            }
                            if (Model.Transitions != null)
                            {
                                for (int i = 0; i < Model.Transitions.Count; i++)
                                {
                                    <input type="hidden" name="Transitions.Index" value="@i" />
                                    <input type="hidden" name="Transitions[@i].FromStateId" value="@Model.Transitions[i].FromStateId" />
                                    <input type="hidden" name="Transitions[@i].ToStateId" value="@Model.Transitions[i].ToStateId" />
                                    <input type="hidden" name="Transitions[@i].Symbol" value="@(Model.Transitions[i].Symbol == '\0' ? "\\0" : Model.Transitions[i].Symbol.ToString())" />
                                    if (Model.Type == AutomatonType.DPDA || Model.Type == AutomatonType.NPDA)
                                    {
                                        if (Model.Transitions[i].StackPop.HasValue)
                                        {
                                            var pop = Model.Transitions[i].StackPop!.Value;
                                            var stackPopValue = pop == '\0' ? "\\0" : pop.ToString();
                                            <input type="hidden" name="Transitions[@i].StackPop" value="@stackPopValue" />
                                        }
                                        if (!string.IsNullOrEmpty(Model.Transitions[i].StackPush))
                                        {
                                            <input type="hidden" name="Transitions[@i].StackPush" value="@Model.Transitions[i].StackPush" />
                                        }
                                    }
                                }
                             if (Model.CurrentStates != null)
                             {
                                 int currentStateIndex = 0;
                                 foreach (var currentState in Model.CurrentStates)
                                 {
                                     <input type="hidden" name="CurrentStates.Index" value="@currentStateIndex" />
                                     <input type="hidden" name="CurrentStates[@currentStateIndex]" value="@currentState" />
                                     currentStateIndex++;
                                 }
                             }
                            }
                        }
                    }
                }

                @{ RenderAutomatonHiddenFieldsForSave(); }

                <input type="hidden" name="saveState" id="saveStateField" value="false" />
                <!-- Layout positions from Cytoscape canvas (populated by JS before submit) -->
                <input type="hidden" name="layoutJson" id="saveLayoutJsonField" value="" />
                <!-- Canvas PNG thumbnail (populated by JS before submit) -->
                <input type="hidden" name="thumbnailBase64" id="saveThumbnailField" value="" />
                <div style="display:flex;gap:0.5rem;justify-content:flex-end;margin-top:0.5rem;">
                    <button type="button" class="modern-btn" id="saveModalCancel">Cancel</button>
                    <button type="submit" class="modern-btn btn-success" id="saveModalSubmitBtn">Save</button>
                </div>
            </form>
        </div>
    </div>
</div>
<script>
(function () {
    var updateUrl = '@Url.Action("Update", "SavedAutomaton")';
    var saveUrl = '@Url.Action("Save", "SavedAutomaton")';

    var intentGroup = document.getElementById('saveIntentGroup');
    var intentUpdate = document.getElementById('saveIntentUpdate');
    var intentNew = document.getElementById('saveIntentNew');
    var form = document.getElementById('saveAutomatonForm');
    var loadedIdField = document.getElementById('saveLoadedId');
    var nameField = document.getElementById('saveName');
    var descField = document.getElementById('saveDescription');
    var submitBtn = document.getElementById('saveModalSubmitBtn');

    function getLoadedContext() {
        var modelLoadedIdField = document.querySelector('input[name="LoadedAutomatonId"]');
        var modelLoadedIdRaw = modelLoadedIdField ? modelLoadedIdField.value : '';
        var parsedModelLoadedId = modelLoadedIdRaw ? parseInt(modelLoadedIdRaw, 10) : NaN;
        var modelLoadedId = Number.isNaN(parsedModelLoadedId) ? null : parsedModelLoadedId;

        var loadedId = window.__loadedAutomatonId ?? modelLoadedId;
        var loadedName = window.__loadedAutomatonName ?? '';
        var loadedDesc = window.__loadedAutomatonDescription ?? '';

        return {
            loadedId: loadedId,
            loadedName: loadedName,
            loadedDesc: loadedDesc
        };
    }

    function applyIntent() {
        var context = getLoadedContext();
        var loadedId = context.loadedId;
        var isUpdate = loadedId && intentUpdate && intentUpdate.checked;
        if (isUpdate) {
            form.action = updateUrl;
            loadedIdField.value = loadedId;
            submitBtn.textContent = 'Update';
        } else {
            form.action = saveUrl;
            loadedIdField.value = '';
            submitBtn.textContent = 'Save';
        }
    }

    // When modal opens pre-fill name/description and set up intent UI
    var openBtn = document.getElementById('openSaveModalBtn');
    if (openBtn) {
        // The real open trigger is external; hook into the modal becoming visible via MutationObserver
        var modal = document.getElementById('saveAutomatonModal');
        if (modal) {
            var observer = new MutationObserver(function () {
                if (modal.style.display !== 'none') {
                        var context = getLoadedContext();
                        var loadedId = context.loadedId;
                        var loadedName = context.loadedName;
                        var loadedDesc = context.loadedDesc;

                    if (loadedId) {
                        if (intentGroup) intentGroup.style.display = '';
                            if (intentUpdate) intentUpdate.checked = true;
                        if (nameField && !nameField.value && loadedName) nameField.value = loadedName;
                        if (descField && !descField.value && loadedDesc) descField.value = loadedDesc;
                    } else {
                        if (intentGroup) intentGroup.style.display = 'none';
                    }
                    applyIntent();
                }
            });
            observer.observe(modal, { attributes: true, attributeFilter: ['style'] });
        }
    }

    if (intentUpdate) intentUpdate.addEventListener('change', applyIntent);
    if (intentNew) intentNew.addEventListener('change', applyIntent);
})();
</script>
