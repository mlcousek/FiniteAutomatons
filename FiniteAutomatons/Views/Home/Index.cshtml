@model AutomatonViewModel
@{
    ViewData["Title"] = "Home";
    var hasExecuted = Model != null && Model.HasExecuted;
    var inputLen = Model?.Input?.Length ?? 0;
    var atStartPos = hasExecuted && Model!.Position <= 0;
    var atEndPos = hasExecuted && Model!.Position >= inputLen && inputLen > 0;
    var disableAllUntilStart = Model == null || !hasExecuted; // initial state before Start
    var analysis = ViewData["MinimizationAnalysis"] as FiniteAutomatons.Services.Interfaces.MinimizationAnalysis;
}
<div class="automaton-workspace">
    @if (TempData["ErrorMessage"] is string err && !string.IsNullOrWhiteSpace(err))
    {
        <div class="alert alert-error minimization-alert" data-test="error-message">@err</div>
    }
    @if (TempData["ConversionMessage"] is string conv && !string.IsNullOrWhiteSpace(conv))
    {
        <div class="alert alert-info minimization-alert" data-test="conversion-message">@conv</div>
    }
    <div class="workspace-grid">
        <div class="create-section">
            <div class="section-header">
                <h2>AUTOMATON</h2>
                <button id="panelsLockBtn" class="panel-lock-btn" title="Lock / unlock panels" aria-pressed="false" type="button">
                    <i class="fas fa-lock-open"></i>
                </button>
                <button id="panelEditModeToggleBtn" class="panel-lock-btn panel-edit-btn" title="Edit Automaton in Panel" type="button"
                        @(Model == null ? "disabled" : "")>
                    <i id="panelEditModeIcon" class="fas fa-pen"></i>
                    <span id="panelEditModeText" style="font-size:0.75rem; margin-left:0.25rem;">Edit</span>
                </button>
            </div>
            <div class="create-content">
                <style>
                    .create-section > .section-header { display: flex; align-items: center; gap: 0.5rem; justify-content: center; white-space: nowrap; }
                    .create-section > .section-header h2 { margin: 0; }
                    .panel-lock-btn { background:transparent;border:0;color:var(--bs-body-color);cursor:pointer;font-size:0.95rem;padding:0 }
                    .panel-lock-btn i { font-size:1.05rem; display:block }
                    .panel-edit-btn { display:flex; align-items:center; gap:0.2rem; padding: 0.15rem 0.4rem; border-radius:4px; transition: background 0.15s; }
                    .panel-edit-btn:hover:not(:disabled) { background: rgba(var(--bs-primary-rgb), 0.12); }
                    .panel-edit-mode-active { background: rgba(var(--bs-warning-rgb), 0.18) !important; color: var(--bs-secondary-color, #6c757d) !important; }
                    .automaton-detail-section[draggable="true"] { cursor: move; }
                    .automaton-detail-section.dragging { opacity:0.6; }
                    .automaton-detail-section.locked { cursor: default; }
                    /* Panel edit controls */
                    .panel-add-btn { display:flex; align-items:center; gap:0.3rem; margin-top:0.5rem; padding:0.3rem 0.6rem;
                        background: rgba(var(--bs-success-rgb),0.12); border:1px solid rgba(var(--bs-success-rgb),0.3);
                        border-radius:4px; color: var(--bs-success); cursor:pointer; font-size:0.82rem; width:100%; justify-content:center;
                        transition: background 0.15s; }
                    .panel-add-btn:hover { background: rgba(var(--bs-success-rgb),0.25); }
                    .panel-delete-btn { background:transparent; border:0; color: rgba(var(--bs-danger-rgb),0.7);
                        cursor:pointer; padding:0 0.25rem; margin-left:auto; font-size:0.85rem; line-height:1;
                        transition: color 0.15s; }
                    .panel-delete-btn:hover { color: var(--bs-danger); }
                    .state-item, .transition-item { display:flex; align-items:center; gap:0.3rem; }
                    .panel-add-transition-form { margin-top:0.5rem; padding:0.5rem 0.3rem 0.3rem; border-top:1px solid rgba(var(--bs-border-color-rgb),0.4); }
                    .panel-add-transition-fields { display:flex; flex-wrap:wrap; gap:0.3rem; align-items:center; }
                    .panel-field { flex:1; min-width:55px; padding:0.2rem 0.4rem; font-size:0.78rem;
                        border:1px solid var(--bs-border-color); border-radius:4px; background:var(--bs-body-bg); color:var(--bs-body-color); }
                    .panel-validation-error { color: var(--bs-danger); font-size:0.78rem; margin-top:0.3rem; width:100%; }
                    /* Badge states in edit mode */
                    .panel-edit-mode-active ~ * .badge-clickable,
                    .badge-clickable { cursor: pointer !important; transition: filter 0.15s, opacity 0.15s; }
                    .badge-clickable:hover { filter: brightness(1.25); }
                    /* Active = flag is set; muted = flag NOT set but visible in edit mode */
                    .state-badge:not(.badge-active) { opacity: 0.32; }
                    .badge-clickable.badge-active { opacity: 1; }
                    /* When NOT in panel edit mode hide the muted inactive badges */
                    body:not(.panel-editing) .state-badge:not(.badge-active) { display: none; }
                </style>

                <div class="input-area" id="panelContainer">
                    @if (Model != null)
                    {
                        @await Html.PartialAsync("~/Views/Home/Partials/_Alphabet.cshtml", Model)

                        @if (!string.IsNullOrWhiteSpace(Model.SourceRegex))
                        {
                            <div class="automaton-detail-section" data-panel-id="source-regex">
                                <h4>Source Regular Expression</h4>
                                <div class="source-regex-display">
                                    <code class="regex-code">@Model.SourceRegex</code>
                                </div>
                            </div>
                        }

                        @await Html.PartialAsync("~/Views/Home/Partials/_States.cshtml", Model)

                        @await Html.PartialAsync("~/Views/Home/Partials/_Transitions.cshtml", Model)

                        @await Html.PartialAsync("~/Views/Home/Partials/_MinimizationReport.cshtml", Model)

                        @await Html.PartialAsync("~/Views/Home/Partials/_ExecutionState.cshtml", Model)
                    }
                    else
                    {
                        <p class="placeholder-text">No automaton loaded</p>
                    }
                </div>
            </div>
        </div>

        <div class="graph-section">
            <div class="section-header">
                <h2>GRAPH</h2>
            </div>
            <div class="graph-content">
                <div class="graph-controls">
                    <button id="zoomInBtn" title="Zoom In" type="button">
                        <i class="fas fa-search-plus"></i>
                    </button>
                    <button id="zoomOutBtn" title="Zoom Out" type="button">
                        <i class="fas fa-search-minus"></i>
                    </button>
                    <button id="fitBtn" title="Fit to View" type="button">
                        <i class="fas fa-compress-arrows-alt"></i>
                    </button>
                    <button id="wheelLockBtn" title="Mouse wheel zoom: ON (click to disable)" type="button" class="control-btn" style="background: transparent; border: none; padding: 0.5rem; color: inherit; display:flex; align-items:center; justify-content:center; border-radius:4px;">
                        <i id="wheelLockIcon" class="fas fa-mouse"></i>
                    </button>
                    <button id="resetLayoutBtn" title="Reset Layout" type="button">
                        <i class="fas fa-sync-alt"></i>
                    </button>
                    <div class="control-separator"></div>
                    <button id="openSaveModalBtnTop" title="Save Automaton" type="button" class="control-btn"
                            @(User?.Identity?.IsAuthenticated ?? false ? "" : "disabled")
                            onclick="document.getElementById('openSaveModalBtn')?.click();">
                        <i class="fas fa-save"></i>
                    </button>
                    <button id="newAutomatonBtn" title="New Automaton" type="button">
                        <i class="fas fa-plus"></i>
                    </button>
                    <button id="generateModalBtn" title="Generate Automaton" type="button">
                        <i class="fas fa-magic"></i>
                    </button>
                    <button id="importBtnToolbar" title="Import Automaton" type="button" onclick="document.getElementById('importUploadInput').click();">
                        <i class="fas fa-file-import"></i>
                    </button>
                    
                    <div class="btn-group" style="display:flex; align-items:stretch; margin: 0;">
                        <button type="button" class="dropdown-toggle" data-bs-toggle="dropdown" aria-expanded="false" title="Export Automaton" @(Model == null ? "disabled" : "") style="background: transparent; border: none; padding: 0.5rem; color: inherit; display:flex; align-items:center; justify-content:center; border-radius:4px; height: 100%;">
                            <i class="fas fa-file-export"></i>
                        </button>
                        <ul class="dropdown-menu">
                            <li>
                                <button type="submit" form="automatonForm" formaction="@Url.Action("ExportText", "ImportExport")" class="dropdown-item" @(Model == null ? "disabled" : "") style="border:none; padding:0.25rem 1rem; width:100%; text-align:left; background:transparent;">
                                    <i class="fas fa-file-download"></i>
                                     Export Text
                                </button>
                            </li>
                            <li>
                                <button type="submit" form="automatonForm" formaction="@Url.Action("ExportJson", "ImportExport")" class="dropdown-item" @(Model == null ? "disabled" : "") style="border:none; padding:0.25rem 1rem; width:100%; text-align:left; background:transparent;">
                                    <i class="fas fa-file-export"></i>
                                     Export JSON
                                </button>
                            </li>
                            <li id="exportWithInputLi" style="display: @(string.IsNullOrEmpty(Model?.Input) ? "none" : "block");">
                                <button type="submit" form="automatonForm" formaction="@Url.Action("ExportWithInput", "ImportExport")" class="dropdown-item" @(Model == null ? "disabled" : "") style="border:none; padding:0.25rem 1rem; width:100%; text-align:left; background:transparent;">
                                    <i class="fas fa-file-download"></i>
                                     Export With Input (JSON)
                                </button>
                            </li>
                            @if (hasExecuted)
                            {
                            <li id="exportWithStateLi">
                                <button type="submit" form="automatonForm" formaction="@Url.Action("ExportJsonWithState", "ImportExport")" class="dropdown-item" @(Model == null ? "disabled" : "") style="border:none; padding:0.25rem 1rem; width:100%; text-align:left; background:transparent;">
                                    <i class="fas fa-file-archive"></i>
                                     Export With State (JSON)
                                </button>
                            </li>
                            }
                        </ul>
                    </div>

                    <form id="importForm" asp-controller="ImportExport" asp-action="ImportAutomaton" method="post" enctype="multipart/form-data" style="display:none;">
                        <input type="file" id="importUploadInput" name="upload" accept=".json,.txt" onchange="document.getElementById('importForm').submit();" />
                    </form>

                    <div class="control-separator"></div>
                    <button id="moveToggleBtn" class="move-mode-btn" title="Toggle Move Mode" type="button">
                        <i id="moveModeIcon" class="fas fa-arrows-alt"></i>
                        <span id="moveModeText">Move</span>
                    </button>
                    <button id="editModeToggleBtn" class="edit-mode-btn" title="Toggle Edit Mode (Lock/Unlock)" type="button" disabled>
                        <i id="editModeIcon" class="fas fa-lock"></i>
                        <span id="editModeText">Locked</span>
                    </button>
                    <div class="control-separator"></div>
                    <button id="undoBtn" title="Undo (Ctrl+Z)" type="button" disabled>
                        <i class="fas fa-undo"></i>
                    </button>
                    <button id="redoBtn" title="Redo (Ctrl+Y)" type="button" disabled>
                        <i class="fas fa-redo"></i>
                    </button>
                </div>
                <div id="automatonCanvasContainer"></div>
            </div>
        </div>
    </div>

    <form asp-controller="Automaton" asp-action="Index" method="post" id="automatonForm">
        @Html.AntiForgeryToken()
        @if (Model != null)
            {
                <input type="hidden" asp-for="Type" />
                <input type="hidden" asp-for="HasExecuted" />
                <input type="hidden" asp-for="Position" />
                <input type="hidden" asp-for="CurrentStateId" />
                <input type="hidden" asp-for="IsAccepted" />
                <input type="hidden" asp-for="StateHistorySerialized" />
                <input type="hidden" asp-for="StackSerialized" />
                <input type="hidden" asp-for="NPDAConfigurationsSerialized" />
                <input type="hidden" asp-for="IsCustomAutomaton" />
                <input type="hidden" name="targetType" id="targetTypeField" />
                @if (Model.States != null)
                {
                    @for (int i = 0; i < Model.States.Count; i++)
                    {
                        <input type="hidden" name="States.Index" value="@i" />
                        <input type="hidden" name="States[@i].Id" value="@Model.States[i].Id" />
                        <input type="hidden" name="States[@i].IsStart" value="@Model.States[i].IsStart.ToString().ToLowerInvariant()" />
                        <input type="hidden" name="States[@i].IsAccepting" value="@Model.States[i].IsAccepting.ToString().ToLowerInvariant()" />
                    }
                }
                @if (Model.Transitions != null)
                {
                    @for (int i = 0; i < Model.Transitions.Count; i++)
                    {
                        <input type="hidden" name="Transitions.Index" value="@i" />
                        <input type="hidden" name="Transitions[@i].FromStateId" value="@Model.Transitions[i].FromStateId" />
                        <input type="hidden" name="Transitions[@i].ToStateId" value="@Model.Transitions[i].ToStateId" />
                        <input type="hidden" name="Transitions[@i].Symbol" value="@(Model.Transitions[i].Symbol == '\0' ? "\\0" : Model.Transitions[i].Symbol.ToString())" />
                        @if (Model.Type == AutomatonType.DPDA || Model.Type == AutomatonType.NPDA)
                        {
                            if (Model.Transitions[i].StackPop.HasValue)
                            {
                                var pop = Model.Transitions[i].StackPop!.Value;
                                var stackPopValue = pop == '\0' ? "\\0" : pop.ToString();
                                <input type="hidden" name="Transitions[@i].StackPop" value="@stackPopValue" />
                            }
                            if (!string.IsNullOrEmpty(Model.Transitions[i].StackPush))
                            {
                                <input type="hidden" name="Transitions[@i].StackPush" value="@Model.Transitions[i].StackPush" />
                            }
                        }
                    }
                }
                @if (Model.CurrentStates != null)
                {
                    @for (int i = 0; i < Model.CurrentStates.Count; i++)
                    {
                        <input type="hidden" name="CurrentStates.Index" value="@i" />
                        <input type="hidden" name="CurrentStates[@i]" value="@Model.CurrentStates.ElementAt(i)" />
                    }
                }
            }

        <div class="control-sections">
            <div class="bottom-left-controls">
                <div class="control-section input-section">
                    <div class="section-header-custom">
                        <h2>INPUT @if (Model?.Type == AutomatonType.DPDA || Model?.Type == AutomatonType.NPDA) { <text>&amp; INITIAL STACK</text> }</h2>
                    </div>
                    <div class="control-content-left" style="display:flex; gap:0.5rem; align-items:stretch; width:100%;">
                        <div style="flex:2; position:relative; display:flex; align-items:stretch;">
                            <input type="text" class="input-field" name="Input" id="inputField"
                               placeholder="Enter input string..."
                               value="@(Model != null ? Model.Input : "")"
                               @(Model != null && Model.HasExecuted ? "readonly" : "")
                               style="flex:1; @(hasExecuted ? "padding: 0.75rem 1rem; border-radius: 6px;" : "padding: 0.75rem 1rem; border-radius: 6px 0 0 6px; border-right: none;")"
                               maxlength="100"
                               oninput="var el = document.getElementById('exportWithInputLi'); if(el) el.style.display = this.value ? 'block' : 'none';" />
                            <button id="generateInputModalBtn" type="button"
                                    class="control-btn"
                                    style="border-radius: 0 6px 6px 0; padding: 0 1rem; white-space: nowrap; display: @(hasExecuted ? "none" : "flex"); align-items: center; gap: 0.4rem;"
                                    @(Model == null ? "disabled" : "")
                                    title="Generate test input for the automaton"
                                    data-generate-input-btn="true">
                                <i class="fas fa-keyboard"></i>
                            </button>
                        </div>
                        @if (Model?.Type == AutomatonType.DPDA || Model?.Type == AutomatonType.NPDA)
                        {
                            string stackDisplay = "";
                            if (!string.IsNullOrEmpty(Model.InitialStackSerialized))
                            {
                                try
                                {
                                    var stackList = System.Text.Json.JsonSerializer.Deserialize<List<char>>(Model.InitialStackSerialized);
                                    if (stackList != null && stackList.Count > 0)
                                    {
                                        stackDisplay = string.Join(",", stackList);
                                    }
                                }
                                catch { /* ignore */ }
                            }
                            <div style="flex:1; display:flex;">
                                <input type="text" class="input-field" id="initialStackDisplayField"
                                   placeholder="Stack (bottom-first)..."
                                   value="@stackDisplay"
                                   @(Model.HasExecuted ? "readonly" : "")
                                   style="padding: 0.75rem 1rem; flex:1;"
                                   maxlength="100"
                                   title="Comma-separated stack symbols, bottom-first (e.g., #,X,Y means # at bottom, Y at top)"
                                   oninput="updateInitialStackSerialized()" />
                                <input type="hidden" name="InitialStackSerialized" id="initialStackSerialized" value="@Model.InitialStackSerialized" />
                            </div>
                        }
                    </div>
                </div>
            </div>

            <div class="bottom-right-controls">
                <div class="control-section simulate-section">
                    <div class="section-header-custom">
                        <h2>SIMULATE</h2>
                    </div>
                    <div class="control-content simulate-buttons">
                        @if (!hasExecuted)
                        {
                            <button type="submit" class="control-btn simulate-btn"
                                    formaction="@Url.Action("Start", "AutomatonExecution")" formmethod="post"
                                    title="Start" data-sim-primary="start">
                                <i class="fas fa-play-circle"></i>
                                <span>Start</span>
                            </button>
                        }
                        @if (hasExecuted)
                        {
                            <button type="submit" class="control-btn simulate-btn"
                                    formaction="@Url.Action("Reset", "AutomatonExecution")" formmethod="post"
                                    title="Reset" data-sim-primary="reset">
                                <i class="fas fa-undo"></i>
                                <span>Reset</span>
                            </button>
                        }

                        @if (disableAllUntilStart || atStartPos)
                        {
                            <button type="submit" class="control-btn simulate-btn" formaction="@Url.Action("BackToStart", "AutomatonExecution")" formmethod="post" title="Back to start" data-sim-action="backToStart" disabled>
                                <i class="fas fa-undo"></i>
                                <span>To start</span>
                            </button>
                        }
                        else
                        {
                            <button type="submit" class="control-btn simulate-btn" formaction="@Url.Action("BackToStart", "AutomatonExecution")" formmethod="post" title="Back to start" data-sim-action="backToStart">
                                <i class="fas fa-undo"></i>
                                <span>To start</span>
                            </button>
                        }

                        @if (disableAllUntilStart || atStartPos)
                        {
                            <button type="submit" class="control-btn simulate-btn" formaction="@Url.Action("StepBackward", "AutomatonExecution")" formmethod="post" title="Step back" data-sim-action="stepBackward" disabled>
                                <i class="fas fa-step-backward"></i>
                                <span>Back</span>
                            </button>
                        }
                        else
                        {
                            <button type="submit" class="control-btn simulate-btn" formaction="@Url.Action("StepBackward", "AutomatonExecution")" formmethod="post" title="Step back" data-sim-action="stepBackward">
                                <i class="fas fa-step-backward"></i>
                                <span>Back</span>
                            </button>
                        }

                        @if (disableAllUntilStart || atEndPos)
                        {
                            <button type="submit" class="control-btn simulate-btn" formaction="@Url.Action("StepForward", "AutomatonExecution")" formmethod="post" title="Read next" data-sim-action="stepForward" disabled>
                                <i class="fas fa-step-forward"></i>
                                <span>Next</span>
                            </button>
                        }
                        else
                        {
                            <button type="submit" class="control-btn simulate-btn" formaction="@Url.Action("StepForward", "AutomatonExecution")" formmethod="post" title="Read next" data-sim-action="stepForward">
                                <i class="fas fa-step-forward"></i>
                                <span>Next</span>
                            </button>
                        }

                        @if (disableAllUntilStart || atEndPos)
                        {
                            <button type="submit" class="control-btn simulate-btn" formaction="@Url.Action("ExecuteAll", "AutomatonExecution")" formmethod="post" title="Read all" data-sim-action="executeAll" disabled>
                                <i class="fas fa-forward"></i>
                                <span>Read all</span>
                            </button>
                        }
                        else
                        {
                            <button type="submit" class="control-btn simulate-btn" formaction="@Url.Action("ExecuteAll", "AutomatonExecution")" formmethod="post" title="Read all" data-sim-action="executeAll">
                                <i class="fas fa-forward"></i>
                                <span>Read all</span>
                            </button>
                        }
                    </div>
                </div>

                <div class="control-section type-section">
                    <div class="section-header-custom">
                        <h2>AUTOMATON TYPE</h2>
                    </div>
                    <div class="control-content type-buttons">
                        <button type="button" class="control-btn type-btn @(Model != null && Model.Type == AutomatonType.DFA ? "active" : "")" data-type="DFA">DFA</button>
                        <button type="button" class="control-btn type-btn @(Model != null && Model.Type == AutomatonType.NFA ? "active" : "")" data-type="NFA">NFA</button>
                        <button type="button" class="control-btn type-btn @(Model != null && Model.Type == AutomatonType.EpsilonNFA ? "active" : "")" data-type="EpsilonNFA">ε-NFA</button>
                        <button type="button" class="control-btn type-btn @(Model != null && Model.Type == AutomatonType.DPDA ? "active" : "")" data-type="DPDA">DPDA</button>
                        <button type="button" class="control-btn type-btn @(Model != null && Model.Type == AutomatonType.NPDA ? "active" : "")" data-type="NPDA">NPDA</button>
                    </div>
                </div>
                @if (Model?.Type == AutomatonType.DPDA || Model?.Type == AutomatonType.NPDA)
                {
                <div class="control-section minimize-section">
                    <div class="section-header-custom">
                        <h2>ACCEPTANCE MODE</h2>
                    </div>
                    <div class="control-content-right" style="display:flex; flex-wrap:wrap; gap:0.5rem; justify-content:center;">
                        @if (Model.HasExecuted)
                        {
                            <select id="acceptanceModeSelect" class="modern-input" style="min-width:200px; padding:0.5rem;" disabled>
                                <option value="0" selected="@(Model.AcceptanceMode == PDAAcceptanceMode.FinalStateAndEmptyStack)">Final State + Empty Stack</option>
                                <option value="1" selected="@(Model.AcceptanceMode == PDAAcceptanceMode.FinalStateOnly)">Final State Only</option>
                                <option value="2" selected="@(Model.AcceptanceMode == PDAAcceptanceMode.EmptyStackOnly)">Empty Stack Only</option>
                            </select>
                            <input type="hidden" name="AcceptanceMode" value="@((int)Model.AcceptanceMode)" />
                        }
                        else
                        {
                            <select name="AcceptanceMode" id="acceptanceModeSelect" class="modern-input" style="min-width:200px; padding:0.5rem;">
                                <option value="0" selected="@(Model.AcceptanceMode == PDAAcceptanceMode.FinalStateAndEmptyStack)">Final State + Empty Stack</option>
                                <option value="1" selected="@(Model.AcceptanceMode == PDAAcceptanceMode.FinalStateOnly)">Final State Only</option>
                                <option value="2" selected="@(Model.AcceptanceMode == PDAAcceptanceMode.EmptyStackOnly)">Empty Stack Only</option>
                            </select>
                        }
                    </div>
                </div>
                }
                else if (Model?.Type == AutomatonType.DFA && analysis != null && analysis.SupportsMinimization)
                {
                <div class="control-section minimize-section">
                    <div class="section-header-custom">
                        <h2>MINIMALIZE</h2>
                    </div>
                    <div class="control-content-right">
                            @{
                            var executionStarted = Model.HasExecuted || Model.Position > 0;
                            }
                            @if (analysis.IsMinimal)
                            {
                                <button type="button" class="control-btn minimize-btn" disabled title="Already minimal">
                                    Minimalize (Already Minimal)
                                </button>
                            }
                            else if (executionStarted)
                            {
                                <button type="button" class="control-btn minimize-btn" disabled title="Execution started">
                                    Minimalize (Disabled - Execution Started)
                                </button>
                            }
                            else
                            {
                                <button type="submit" class="control-btn minimize-btn"
                                        formaction="@Url.Action("Minimalize", "AutomatonExecution")" formmethod="post" title="Minimalize DFA">
                                    Minimalize (→ @analysis.MinimizedStateCount)
                                </button>
                        }
                    </div>
                </div>
                }
                else
                {
                <div class="control-section minimize-section">
                    <div class="section-header-custom">
                        <h2>MINIMALIZE</h2>
                    </div>
                    <div class="control-content-right">
                            <button type="button" class="control-btn minimize-btn" disabled title="Unsupported automaton type">
                            Minimalize (Disabled - Unsupported automaton type)
                        </button>
                    </div>
                </div>
                }
            </div>
        </div>
    </form>
    @await Html.PartialAsync("~/Views/Home/Partials/_GenerateInputModal.cshtml", Model)
        </div>
            @await Html.PartialAsync("~/Views/Home/Partials/_GenerateModal.cshtml", Model)
        @if (User?.Identity?.IsAuthenticated ?? false)
        {
                @await Html.PartialAsync("~/Views/Home/Partials/_SaveAutomatonModal.cshtml", Model)
        }

